# skill-chain.py loads this file (copy to .env) before spawning a harness.
# Exported environment variables still take precedence; .env fills the gaps.
# .env is gitignored — never commit real keys. Values may be quoted.

# Cursor harness (--harness cursor / AGENT_HARNESS=cursor).
# User API Key from the Cursor Dashboard -> API Keys. Required for headless
# `cursor-agent -p` (the interactive login token is not accepted there).
CURSOR_API_KEY=

# Optional: pin the Cursor model. Defaults to "grok" when unset.
CURSOR_MODEL=grok
