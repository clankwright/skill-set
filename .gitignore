# Per-job run logs (each consuming project keeps its own outside this repo;
# any local symlinks or test logs land here too)
.skill-runs/

# Generated proposal scratch (real proposals live under proposals/ and are
# committed; a contributor's local sandbox sits here)
proposals/.scratch/

# Python
__pycache__/
*.pyc
.venv/

# OS
.DS_Store

# Claude Code runtime state (local to each clone)
.claude/

# playwright-mcp browser session artifacts (local, regenerated per run)
.playwright-mcp/

# sanitize-transferable audit artifacts (regenerate on demand; never commit)
*.findings.md
*.sanitized.md

# Shared Telegram channel credentials (base-dir fallback for consuming projects)
telegram.env

# Brave Search API keys (Cursor-harness WebSearch/WebFetch substitute; base-dir
# fallback for bin/brave-web.py — BRAVE_SEARCH_API_KEY_FREE + BRAVE_SEARCH_API_KEY)
brave.env

# Local credentials loaded by skill-chain.py (CURSOR_API_KEY, CURSOR_MODEL, ...)
# — never commit. Templates like .env.example stay tracked.
.env
.env.local
